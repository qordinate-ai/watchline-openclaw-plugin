{
  "id": "watchline",
  "activation": {
    "onStartup": true
  },
  "name": "Watchline",
  "description": "Deliver matched Watchline events into OpenClaw from a local pull channel.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "Watchline project API key."
      },
      "channelId": {
        "type": "string",
        "description": "Watchline pull channel ID."
      },
      "sessionKey": {
        "type": "string",
        "description": "Optional OpenClaw session key override for proactive Watchline events. Defaults to the main session."
      },
      "apiBaseUrl": {
        "type": "string",
        "description": "Watchline API base URL."
      },
      "userId": {
        "type": "string",
        "description": "Default Watchline user_id for personal OpenClaw watches."
      },
      "pollIntervalSeconds": {
        "type": "number",
        "description": "Seconds between pull-delivery polls."
      }
    }
  }
}

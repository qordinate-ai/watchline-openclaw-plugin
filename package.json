{
  "name": "@watchline/openclaw-plugin",
  "version": "0.1.2",
  "description": "OpenClaw plugin for registering Watchline event watches and receiving matched events.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "homepage": "https://watch.qordinate.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qordinate-ai/watchline-openclaw-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/qordinate-ai/watchline-openclaw-plugin/issues"
  },
  "keywords": [
    "openclaw",
    "watchline",
    "agents",
    "event-layer",
    "proactive-agents",
    "mcp",
    "plugin"
  ],
  "engines": {
    "node": ">=22.12"
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist",
    "!dist/**/*.map",
    "openclaw.plugin.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./dist/plugin.js"
    ]
  },
  "dependencies": {
    "@watchline/sdk-js": "^0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm build",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "packageManager": "pnpm@11.1.1"
}
